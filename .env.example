# Copy to .env for local dev. All vars are prefixed FP_.

# dev | prod  (prod requires FP_ENCRYPTION_KEY to be set explicitly)
FP_ENV=dev

# HTTP listen address and the externally-reachable base URL (used for OAuth redirects later)
FP_ADDR=:8080
FP_BASE_URL=http://localhost:8080

# Where the SQLite db + cached files live
FP_DATA_DIR=./data

# Secret used to derive the AES-256 key that encrypts stored credentials.
# Any length string; it is hashed to 32 bytes. REQUIRED in prod.
FP_ENCRYPTION_KEY=dev-insecure-key-change-me

# Bootstrap admin passphrase: on first run, if no passphrase is set in the DB,
# this is hashed (argon2id) and stored. Change it, then you can remove this var.
FP_ADMIN_PASSPHRASE=changeme

# Locale + timezone (drives Dutch UI, date formatting, countdown math)
FP_LOCALE=nl
FP_TIMEZONE=Europe/Brussels

# Admin session length in days (kiosk device token is permanent)
FP_SESSION_DAYS=90

# App-level OAuth client credentials (one app per provider). Data sources then
# only need an interactive sign-in (the user's token is stored encrypted).
# Microsoft app (used by Outlook calendar, To Do, and OneDrive photos):
FP_MS_CLIENT_ID=
FP_MS_CLIENT_SECRET=
# Google app (used by Google Photos, if ever enabled):
FP_GOOGLE_CLIENT_ID=
FP_GOOGLE_CLIENT_SECRET=
