package web

import (
	"fmt"

	"github.com/jvmeir/familyplanner/internal/i18n"
)

// DataSourcesPage lists reusable data sources (iCal feeds, later OAuth) + create form.
templ DataSourcesPage(types []WidgetTypeVM, initialFields []FieldVM, sources []DataSourceVM) {
	@AdminPage("datasources") {
		<h1>{ i18n.T(ctx, "nav.datasources") }</h1>
		<form class="card form" hx-post="/admin/datasources" hx-target="#dslist" hx-swap="outerHTML">
			@csrfInput()
			<label>
				{ i18n.T(ctx, "admin.field_name") }
				<input name="name" required/>
			</label>
			<label>
				{ i18n.T(ctx, "admin.field_type") }
				<select name="type" hx-get="/admin/datasources/fields" hx-target="#dsfields" hx-trigger="change">
					for _, t := range types {
						<option value={ t.ID }>{ t.Name }</option>
					}
				</select>
			</label>
			<div id="dsfields">
				@WidgetFields(initialFields)
			</div>
			<button type="submit">{ i18n.T(ctx, "admin.add") }</button>
		</form>
		@DataSourceList(sources)
	}
}

// DataSourceList is the (HTMX-swappable) list of data sources.
templ DataSourceList(sources []DataSourceVM) {
	<div id="dslist" class="list">
		if len(sources) == 0 {
			<p class="muted">{ i18n.T(ctx, "admin.empty") }</p>
		}
		for _, d := range sources {
			<div class="row">
				<input
					class="row-name rename"
					name="name"
					value={ d.Name }
					hx-post={ "/admin/datasources/" + fmt.Sprint(d.ID) + "/name" }
					hx-trigger="change"
					hx-target="#dslist"
					hx-swap="outerHTML"
					aria-label={ i18n.T(ctx, "admin.rename") }
				/>
				<span class="row-type">{ i18n.T(ctx, "datasource.type." + d.Type) }</span>
				if d.HealthText != "" {
					<span class={ "hpill", "hpill-" + d.HealthLevel } title={ d.LastError }>{ d.HealthText }</span>
				}
				if d.HasConfig {
					<a class="btn ghost" href={ templ.SafeURL("/admin/datasources/" + fmt.Sprint(d.ID) + "/edit") }>{ i18n.T(ctx, "admin.edit") }</a>
				}
				if d.IsOAuth {
					<a class="btn ghost" href={ templ.SafeURL("/admin/datasources/" + fmt.Sprint(d.ID) + "/oauth/start") }>{ i18n.T(ctx, "datasource.connect") }</a>
				}
				<button class="btn ghost" hx-delete={ "/admin/datasources/" + fmt.Sprint(d.ID) } hx-target="#dslist" hx-swap="outerHTML" hx-confirm={ i18n.T(ctx, "admin.confirm_delete") }>×</button>
			</div>
		}
	</div>
}

// DataSourceEditPage edits a data source's config fields (e.g. iCal/RSS URL,
// text lines) after creation.
templ DataSourceEditPage(id int64, name string, typeName string, fields []FieldVM) {
	@AdminPage("datasources") {
		<h1>{ name }</h1>
		<form class="card form" method="post" action={ templ.SafeURL("/admin/datasources/" + fmt.Sprint(id)) }>
			@csrfInput()
			<label>
				{ i18n.T(ctx, "admin.field_name") }
				<input name="name" value={ name } required/>
			</label>
			<p class="muted">{ i18n.T(ctx, "admin.field_type") }: { typeName }</p>
			@WidgetFields(fields)
			<div class="btn-row">
				<button type="submit">{ i18n.T(ctx, "admin.save") }</button>
				<a class="btn ghost" href="/admin/datasources">{ i18n.T(ctx, "admin.back") }</a>
			</div>
		</form>
	}
}

// WidgetSources is the per-widget data-source linking section (on the edit page).
templ WidgetSources(widgetID int64, linked []WidgetSourceVM, available []DataSourceVM) {
	<div id="wsources" class="card">
		<h2>{ i18n.T(ctx, "datasource.sources") }</h2>
		<p class="muted">{ i18n.T(ctx, "datasource.sources_hint") }</p>
		<div class="list">
			if len(linked) == 0 {
				<p class="muted">{ i18n.T(ctx, "datasource.none_linked") }</p>
			}
			for _, l := range linked {
				<div class="row">
					<span class="row-name">{ l.SourceName }</span>
					<span class="row-type">{ i18n.T(ctx, "datasource.type." + l.SourceType) }</span>
					if l.HasPicker {
						<select name="resource"
							hx-post={ fmt.Sprintf("/admin/widgets/%d/sources/%d/resource", widgetID, l.LinkID) }
							hx-target="#wsources" hx-swap="outerHTML" hx-trigger="change"
							aria-label={ l.ResourceLabel }>
							<option value="">{ l.ResourceLabel }…</option>
							for _, o := range l.ResourceOptions {
								<option value={ o.Value } selected?={ o.Selected }>{ o.Label }</option>
							}
						</select>
					}
					if l.Filter != "" {
						<span class="row-type">{ i18n.T(ctx, "widget.calendar.field.filter") }: { l.Filter }</span>
					}
					if l.ShowColor {
						<input type="color" class="ws-color" value={ colorOrDefault(l.Color) }
							title={ i18n.T(ctx, "datasource.color") }
							hx-post={ fmt.Sprintf("/admin/widgets/%d/sources/%d/color", widgetID, l.LinkID) }
							hx-target="#wsources" hx-swap="outerHTML" hx-trigger="change"
							name="color"/>
					}
					<button class="btn ghost" hx-delete={ fmt.Sprintf("/admin/widgets/%d/sources/%d", widgetID, l.LinkID) } hx-target="#wsources" hx-swap="outerHTML">×</button>
				</div>
			}
		</div>
		if len(available) > 0 {
			<form class="form inline" hx-post={ fmt.Sprintf("/admin/widgets/%d/sources", widgetID) } hx-target="#wsources" hx-swap="outerHTML">
				@csrfInput()
				<label>
					{ i18n.T(ctx, "datasource.source") }
					<select name="data_source_id">
						for _, a := range available {
							<option value={ fmt.Sprint(a.ID) }>{ a.Name } — { i18n.T(ctx, "datasource.type." + a.Type) }</option>
						}
					</select>
				</label>
				<label>
					{ i18n.T(ctx, "widget.calendar.field.filter") }
					<input name="filter"/>
				</label>
				<button type="submit">{ i18n.T(ctx, "admin.add") }</button>
			</form>
		} else {
			<p class="muted">{ i18n.T(ctx, "datasource.create_first") }</p>
		}
	</div>
}
